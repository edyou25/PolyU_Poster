\ProvidesPackage{beamerthemePolyU}

\RequirePackage{fontawesome5}
\RequirePackage{graphicx}
\RequirePackage{tikz}

\mode<presentation>

\definecolor{jaune}{RGB}{220,180,60}
\definecolor{saclaydk}{RGB}{166,25,46} % PolyU Red
\definecolor{saclayl}{RGB}{236,219,222}
\definecolor{prunel}{RGB}{242,232,234}
\definecolor{vertl}{RGB}{231,234,236}
\definecolor{vert}{RGB}{87,88,90}
\definecolor{rouge}{RGB}{166,25,46} % PolyU Red
\definecolor{mandarine}{RGB}{87,88,90}
\definecolor{bleu}{RGB}{120,120,120}

\setbeamercolor{headline}{fg=black,bg=white}
\setbeamercolor{headline accent}{bg=saclaydk}
\setbeamercolor{footline}{fg=white,bg=saclaydk}
\setbeamerfont{footline}{size=\large}
\setbeamercolor{separation line}{bg=saclaydk}
\setbeamercolor{title in headline}{fg=black}
\setbeamercolor{author in headline}{fg=black}
\setbeamercolor{institute in headline}{fg=black}
\setbeamercolor{framesubtitle}{fg=mandarine,bg=gray}
\setbeamercolor{author in head/foot}{fg=white,bg=black}
\setbeamercolor{title in head/foot}{fg=white,bg=saclaydk}

\setbeamercolor*{block body}{bg=prunel,fg=black}
\setbeamercolor*{block title}{fg=white,bg=saclaydk}
\setbeamerfont*{block title}{size=\Large,series=\bf}
\setbeamercolor*{block text}{fg=saclaydk,bg=vertl}
\setbeamercolor*{example body}{bg=vertl,fg=black}
\setbeamercolor*{example text}{fg=saclaydk,bg=vertl}
\setbeamercolor*{example title}{bg=vert,fg=white}

\setbeamercolor{alerted body}{bg=mandarine!20,fg=black}
\setbeamercolor{alerted title}{fg=white,bg=rouge}
\setbeamercolor{alerted text}{fg=white,bg=rouge}

\setbeamercolor{structure}{fg=saclaydk}

\setbeamertemplate{itemize items}[triangle]
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{blocks}[rounded]

\setbeamertemplate{block begin}{
  \vskip.75ex
  \begin{beamercolorbox}[ht=3.5ex,dp=0.5ex,center,leftskip=-1em,colsep*=.75ex]{block title}%
    \usebeamerfont*{block title}%
    {\phantom{Gg}\insertblocktitle}%
  \end{beamercolorbox}%
  {\ifbeamercolorempty[bg]{block body}{}{\nointerlineskip\vskip-0.5pt}}%
  \usebeamerfont{block body}%
  \begin{beamercolorbox}[leftskip=1em,colsep*=.75ex,sep=0.5ex,vmode]{block body}%
    \ifbeamercolorempty[bg]{block body}{\vskip-.25ex}{\vskip-.75ex}\vbox{}%
  }
  \setbeamertemplate{block end}{
  \end{beamercolorbox}
}

\newcommand{\PolyULogoGraphic}[1]{%
  \IfFileExists{assets/polyu.pdf}{%
    \includegraphics[width=#1]{assets/polyu.pdf}%
  }{%
    \IfFileExists{assets/polyu.png}{%
      \includegraphics[width=#1]{assets/polyu.png}%
    }{%
      \fbox{%
        \parbox[c][0.22\paperwidth][c]{#1}{%
          \centering
          \bfseries\Large PolyU
        }%
      }%
    }%
  }%
}

\setbeamertemplate{headline}{
  \leavevmode

  \begin{beamercolorbox}[wd=.72\paperwidth,leftskip=.04\paperwidth,rightskip=0pt,sep=0pt,vmode]{headline}
    \vskip0.8ex
    \raggedright
    \usebeamercolor{title in headline}{\color{fg}\textbf{\huge \inserttitle}\par}
    \vspace{0.6ex}
    \usebeamercolor{author in headline}{\color{fg}\Large \insertauthor\par}
    \vspace{0.4ex}
    \usebeamercolor{institute in headline}{\color{fg}\large \insertinstitute\par}
    \vskip0.8ex
  \end{beamercolorbox}%

  \begin{tikzpicture}[remember picture,overlay]
    \node[anchor=north east,inner sep=0pt] at ([xshift=-0.6cm,yshift=-1.0cm]current page.north east) {\PolyULogoGraphic{0.27\paperwidth}};
  \end{tikzpicture}

  \begin{beamercolorbox}[wd=\paperwidth]{headline accent}
    \rule{0pt}{4pt}
  \end{beamercolorbox}
}

\setbeamertemplate{footline}{
  \leavevmode%
  \begin{beamercolorbox}[wd=\paperwidth,ht=6ex,dp=3ex,leftskip=2em,rightskip=2em]{footline}%
    \usebeamercolor{footline}%
    \large\bfseries
    \faEnvelope \; your.email@polyu.edu.hk
    \hfill
    The Hong Kong Polytechnic University
    \hfill
    \faGlobe \; www.polyu.edu.hk
  \end{beamercolorbox}
  \vskip0pt%
  \begin{beamercolorbox}[wd=\paperwidth]{lower separation line foot}
    \rule{0pt}{3pt}\color{saclaydk}
  \end{beamercolorbox}
}

% Uncomment the next line if you want the alignment grid while editing.
% \beamertemplategridbackground[1cm]

\mode<all>

\setbeamertemplate{itemize items}[triangle]
\setbeamertemplate{itemize item}{\raisebox{0.12ex}{\faSplotch}\hskip0.1em}
\setbeamertemplate{itemize subitem}{\raisebox{0.12ex}{$\triangleright$}\hskip0.1em}

\setbeamerfont{block body}{size=\large}
\setbeamerfont{itemize/enumerate body}{size=\large}
\setbeamerfont{itemize/enumerate subbody}{size=\normalsize}
\setbeamerfont{itemize/enumerate subsubbody}{size=\normalsize}
